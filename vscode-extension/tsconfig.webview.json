{
    "compilerOptions": {
        "module": "esnext",
        "target": "ES2022",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": [],
        "noEmit": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "resolveJsonModule": true
    },
    "include": ["src/webview/**/*"],
    "exclude": ["node_modules"]
}
